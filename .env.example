# Copy this file to `.env` and fill in your Firebase project's values.
# Find these in the Firebase console under Project Settings → General →
# "Your apps" → SDK setup and configuration.
#
# NOTE: `.env` is gitignored. Never commit real credentials.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_DATABASE_URL=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Set to "true" to run against in-memory mock services instead of real
# Firebase. Useful for local UI development without a Firebase project.
# VITE_MOCK_BACKEND=true
