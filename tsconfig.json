{
	"compilerOptions": {
		"target": "ESNext",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"allowSyntheticDefaultImports": true,
		"esModuleInterop": true,
		"jsx": "preserve",
		"jsxImportSource": "solid-js",
		"allowJs": true,
		"strict": true,
		"skipLibCheck": true,
		"noEmit": true,
		"types": [
			"vinxi/types/client",
			"vitest/globals",
			"@testing-library/jest-dom"
		],
		"isolatedModules": true,
		"paths": {
			"~/*": ["./src/*"]
		}
	}
}
